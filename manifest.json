{
  "manifest_version": 3,
  "name": "ResumeMatch",
  "version": "2.0.0",
  "description": "Tailor your resume and build your Answer Bank for any job",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "http://localhost/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "onboarding.html",
        "onboarding.css",
        "onboarding.js",
        "utils/pdfExtractor.js",
        "lib/pdf.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}